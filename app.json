{
  "expo": {
    "name": "Penny Budget",
    "slug": "Penny-Budget",
    "scheme": "pennybudget",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gary.pennybudget",
      "buildNumber": "7",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.gary.pennybudget",
      "adaptiveIcon": {
        "backgroundColor": "#5A3AE0",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "versionCode": 3
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-apple-authentication",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Penny Budget uses Face ID to unlock the app and keep your budget private."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "65822f93-8765-417b-81dc-bff4f58011c2"
      }
    },
    "owner": "gauravchoukse22"
  }
}
